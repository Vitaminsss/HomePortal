# ─── HomePortal 环境配置 ───────────────────────────────────────────────────────
# 复制此文件为 .env 并填写实际值

# 监听端口（默认 3000）
PORT=3000

# 管理员密码（未设置时默认为 rainy，生产环境请务必在 .env 中改为强密码）
# ADMIN_PASSWORD=rainy

# JWT 签名密钥（必须修改为随机长字符串！）
JWT_SECRET=change-me-to-a-random-secret-string

# 门户标题（显示在页面顶部，未设置时默认为「指引页」）
# PORTAL_TITLE=指引页
